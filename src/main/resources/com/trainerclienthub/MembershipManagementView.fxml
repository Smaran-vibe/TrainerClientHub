<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trainerclienthub.controller.MembershipController"
            styleClass="root-pane"
            stylesheets="@css/neon-theme.css">

    <!-- ── LEFT: Sidebar ── -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-logo-box" spacing="4">
                <Label styleClass="sidebar-logo-title" text="TCH"/>
                <Label styleClass="sidebar-logo-sub"   text="TRAINER CLIENT HUB"/>
            </VBox>
            <Region styleClass="sidebar-divider"/>
            <Label styleClass="sidebar-section-label" text="MAIN MENU"/>
            <HBox fx:id="navDashboard" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavDashboard">
                <Label styleClass="nav-icon" text="⊞"/><Label text="Dashboard"/>
            </HBox>
            <HBox fx:id="navClients" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavClients">
                <Label styleClass="nav-icon" text="👥"/><Label text="Clients"/>
            </HBox>
            <HBox fx:id="navWorkouts" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavWorkouts">
                <Label styleClass="nav-icon" text="🏋"/><Label text="Workouts"/>
            </HBox>
            <HBox styleClass="nav-item, nav-item-active" spacing="12" alignment="CENTER_LEFT">
                <Label styleClass="nav-icon" text="🪪"/><Label text="Memberships"/>
            </HBox>
            <HBox fx:id="navSessions" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavSessions">
                <Label styleClass="nav-icon" text="📅"/><Label text="Sessions"/>
            </HBox>
            <HBox fx:id="navReports" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavReports">
                <Label styleClass="nav-icon" text="📊"/><Label text="Reports"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleLogout">
                <Label styleClass="nav-icon" text="⏻"/><Label text="Logout" style="-fx-text-fill:#AAAAAA;"/>
            </HBox>
        </VBox>
    </left>

    <!-- ── TOP: Top bar ── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="2">
                <Label styleClass="top-bar-title" text="Membership Management"/>
                <Label styleClass="top-bar-subtitle" text="Assign, renew and manage client memberships"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="avatar-circle">
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="T"/>
            </StackPane>
        </HBox>
    </top>

    <!-- ── CENTER ── -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Tab bar: All Memberships / Membership Plans -->
            <TabPane fx:id="membershipTabs" styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE">

                <!-- Tab 1: All Memberships -->
                <Tab text="All Memberships">
                    <VBox spacing="16" style="-fx-padding: 16 0 0 0;">

                        <!-- Action bar -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TextField fx:id="membershipSearchField" styleClass="search-field"
                                       promptText="Search by client name..."/>
                            <ComboBox fx:id="statusFilter" styleClass="combo-box"
                                      promptText="All Statuses" prefWidth="160">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="All"/>
                                        <String fx:value="ACTIVE"/>
                                        <String fx:value="EXPIRED"/>
                                        <String fx:value="CANCELLED"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="assignMembershipBtn" styleClass="btn-primary"
                                    text="+ Assign Membership" onAction="#handleAssignMembership"/>
                            <Button fx:id="renewBtn" styleClass="btn-secondary"
                                    text="Renew" onAction="#handleRenewMembership"/>
                            <Button fx:id="cancelMembershipBtn" styleClass="btn-danger"
                                    text="Cancel" onAction="#handleCancelMembership"/>
                        </HBox>

                        <!-- Membership table -->
                        <TableView fx:id="membershipTable" VBox.vgrow="ALWAYS"
                                   styleClass="table-view" prefHeight="500">
                            <columns>
                                <TableColumn fx:id="colMemId"       text="ID"         prefWidth="60"/>
                                <TableColumn fx:id="colMemClient"   text="CLIENT"     prefWidth="160"/>
                                <TableColumn fx:id="colMemPlan"     text="PLAN"       prefWidth="150"/>
                                <TableColumn fx:id="colMemType"     text="TYPE"       prefWidth="110"/>
                                <TableColumn fx:id="colMemStart"    text="START DATE" prefWidth="120"/>
                                <TableColumn fx:id="colMemEnd"      text="END DATE"   prefWidth="120"/>
                                <TableColumn fx:id="colMemStatus"   text="STATUS"     prefWidth="110"/>
                                <TableColumn fx:id="colDaysLeft"    text="DAYS LEFT"  prefWidth="100"/>
                            </columns>
                            <placeholder>
                                <Label text="No memberships found."
                                       style="-fx-text-fill:#555555; -fx-font-size:13px;"/>
                            </placeholder>
                        </TableView>

                    </VBox>
                </Tab>

                <!-- Tab 2: Membership Plans -->
                <Tab text="Membership Plans">
                    <VBox spacing="16" style="-fx-padding: 16 0 0 0;">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="addPlanBtn" styleClass="btn-primary"
                                    text="+ New Plan" onAction="#handleAddPlan"/>
                            <Button fx:id="editPlanBtn" styleClass="btn-secondary"
                                    text="Edit Plan" onAction="#handleEditPlan"/>
                            <Button fx:id="deletePlanBtn" styleClass="btn-danger"
                                    text="Delete" onAction="#handleDeletePlan"/>
                        </HBox>

                        <TableView fx:id="planTable" VBox.vgrow="ALWAYS"
                                   styleClass="table-view" prefHeight="460">
                            <columns>
                                <TableColumn fx:id="colPlanId"       text="ID"           prefWidth="60"/>
                                <TableColumn fx:id="colPlanName"     text="PLAN NAME"    prefWidth="200"/>
                                <TableColumn fx:id="colPlanType"     text="TYPE"         prefWidth="120"/>
                                <TableColumn fx:id="colPlanDuration" text="DURATION"     prefWidth="120"/>
                                <TableColumn fx:id="colPlanPrice"    text="PRICE (NPR)"  prefWidth="140"/>
                            </columns>
                            <placeholder>
                                <Label text="No plans created yet."
                                       style="-fx-text-fill:#555555; -fx-font-size:13px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

            </TabPane>
        </VBox>
    </center>

    <!-- ── RIGHT: Assign membership / Plan form panel ── -->
    <right>
        <VBox fx:id="membershipFormPanel" styleClass="form-panel" spacing="16"
              minWidth="300" maxWidth="300" managed="false" visible="false">

            <Label fx:id="membershipFormTitle" styleClass="form-panel-title" text="Assign Membership"/>
            <Region styleClass="divider-line"/>

            <!-- Client -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="CLIENT *"/>
                <ComboBox fx:id="fMemClient" styleClass="combo-box"
                          promptText="Select client..." prefWidth="Infinity"/>
            </VBox>

            <!-- Plan -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="MEMBERSHIP PLAN *"/>
                <ComboBox fx:id="fMemPlan" styleClass="combo-box"
                          promptText="Select plan..." prefWidth="Infinity"
                          onAction="#handlePlanSelected"/>
            </VBox>

            <!-- Plan preview -->
            <VBox fx:id="planPreviewBox" spacing="6"
                  style="-fx-background-color:#1A2000; -fx-background-radius:8; -fx-padding:12;"
                  managed="false" visible="false">
                <Label fx:id="planPreviewName"  style="-fx-text-fill:#CCFF00; -fx-font-weight:bold;" text=""/>
                <Label fx:id="planPreviewPrice" style="-fx-text-fill:#FFFFFF;" text=""/>
                <Label fx:id="planPreviewDays"  style="-fx-text-fill:#AAAAAA; -fx-font-size:11px;" text=""/>
            </VBox>

            <!-- Start date -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="START DATE *"/>
                <DatePicker fx:id="fMemStartDate" styleClass="date-picker" prefWidth="Infinity"
                            onAction="#handleStartDateSelected"/>
            </VBox>

            <!-- End date (auto-filled) -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="END DATE (auto-calculated)"/>
                <DatePicker fx:id="fMemEndDate" styleClass="date-picker" prefWidth="Infinity"/>
            </VBox>

            <!-- Validation error -->
            <Label fx:id="memFormErrorLabel" styleClass="text-danger"
                   text="" wrapText="true" style="-fx-font-size:12px;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="10" minHeight="40" alignment="CENTER">
                <Button fx:id="formSaveBtn"
                        styleClass="btn-primary"
                        text="Save Membership"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        onAction="#handleSaveMembership"
                        minHeight="40"/>

                <Button fx:id="formCancelBtn"
                        styleClass="btn-secondary"
                        text="Cancel"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        onAction="#handleCancelMemForm"
                        minHeight="40"/>
            </HBox>

        </VBox>
    </right>

</BorderPane>
