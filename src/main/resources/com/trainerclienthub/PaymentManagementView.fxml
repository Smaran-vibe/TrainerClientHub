<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trainerclienthub.controller.PaymentController"
            styleClass="root-pane"
            stylesheets="css/neon-theme.css">

    <!-- ── LEFT: Sidebar ── -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-logo-box" spacing="4">
                <Label styleClass="sidebar-logo-title" text="TCH"/>
                <Label styleClass="sidebar-logo-sub" text="TRAINER CLIENT HUB"/>
            </VBox>
            <Region styleClass="sidebar-divider"/>
            <Label styleClass="sidebar-section-label" text="MAIN MENU"/>
            <HBox fx:id="navDashboard" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavDashboard">
                <Label styleClass="nav-icon" text="⊞"/>
                <Label text="Dashboard"/>
            </HBox>
            <HBox fx:id="navClients" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavClients">
                <Label styleClass="nav-icon" text="👥"/>
                <Label text="Clients"/>
            </HBox>
            <HBox fx:id="navWorkouts" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavWorkouts">
                <Label styleClass="nav-icon" text="🏋"/>
                <Label text="Workouts"/>
            </HBox>
            <HBox fx:id="navMemberships" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavMemberships">
                <Label styleClass="nav-icon" text="🪪"/>
                <Label text="Memberships"/>
            </HBox>
            <HBox fx:id="navSessions" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavSessions">
                <Label styleClass="nav-icon" text="📅"/>
                <Label text="Sessions"/>
            </HBox>
            <!-- Active page -->
            <HBox styleClass="nav-item, nav-item-active" spacing="12" alignment="CENTER_LEFT">
                <Label styleClass="nav-icon" text="💳"/>
                <Label text="Payments"/>
            </HBox>
            <HBox fx:id="navReports" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavReports">
                <Label styleClass="nav-icon" text="📊"/>
                <Label text="Reports"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleLogout">
                <Label styleClass="nav-icon" text="⏻"/>
                <Label text="Logout" style="-fx-text-fill:#AAAAAA;"/>
            </HBox>
        </VBox>
    </left>

    <!-- ── TOP: Top bar ── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="2">
                <Label styleClass="top-bar-title" text="Payment Management"/>
                <Label styleClass="top-bar-subtitle" text="Track and record membership payments"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="avatar-circle">
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="T"/>
            </StackPane>
        </HBox>
    </top>

    <!-- ── CENTER: Main content ── -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Summary row -->
            <HBox spacing="16">
                <!-- Total Revenue card -->
                <VBox styleClass="summary-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="card-icon-box">
                            <Label styleClass="card-icon" text="₨"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label styleClass="card-label" text="TOTAL REVENUE"/>
                            <Label fx:id="totalRevenueLabel" styleClass="card-value" text="Rs 0"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region styleClass="card-accent-dot"/>
                        <Label fx:id="totalRevenueSubLabel" styleClass="card-trend-up" text="all-time"/>
                    </HBox>
                </VBox>

                <!-- Monthly Revenue card -->
                <VBox styleClass="summary-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="card-icon-box">
                            <Label styleClass="card-icon" text="📅"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label styleClass="card-label" text="THIS MONTH"/>
                            <Label fx:id="monthlyRevenueLabel" styleClass="card-value" text="Rs 0"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region styleClass="card-accent-dot"/>
                        <Label fx:id="paymentCountLabel" styleClass="card-trend-up" text="0 payments"/>
                    </HBox>
                </VBox>

                <!-- Payment count card -->
                <VBox styleClass="summary-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="card-icon-box">
                            <Label styleClass="card-icon" text="🧾"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label styleClass="card-label" text="TOTAL PAYMENTS"/>
                            <Label fx:id="totalCountLabel" styleClass="card-value" text="0"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region styleClass="card-accent-dot"/>
                        <Label styleClass="card-trend-up" text="all records"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Filter + action bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           styleClass="search-field"
                           promptText="Search by client name..."
                           prefWidth="260"/>
                <DatePicker fx:id="filterFrom" styleClass="date-picker" promptText="From date"/>
                <DatePicker fx:id="filterTo" styleClass="date-picker" promptText="To date"/>
                <Button styleClass="btn-secondary" text="Filter" onAction="#handleFilter"/>
                <Button styleClass="btn-secondary" text="Clear" onAction="#handleClearFilter"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="addPaymentBtn" styleClass="btn-primary"
                        text="+ Record Payment" onAction="#handleAddPayment"/>
            </HBox>

            <!-- Payments table -->
            <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colPaymentId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colClientName" text="CLIENT" prefWidth="180"/>
                    <TableColumn fx:id="colMembershipPlan" text="PLAN" prefWidth="160"/>
                    <TableColumn fx:id="colAmount" text="AMOUNT (NPR)" prefWidth="140"/>
                    <TableColumn fx:id="colPaymentDate" text="DATE" prefWidth="130"/>
                    <TableColumn fx:id="colPaymentMethod" text="METHOD" prefWidth="120"/>
                    <TableColumn fx:id="colPaymentStatus" text="STATUS" prefWidth="110"/>
                </columns>
                <placeholder>
                    <Label text="No payments found." style="-fx-text-fill:#555555; -fx-font-size:14px;"/>
                </placeholder>
            </TableView>

            <!-- Status bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="paymentTableCountLabel"
                       style="-fx-text-fill:#555555; -fx-font-size:12px;"
                       text="0 payments"/>
            </HBox>

        </VBox>
    </center>

    <!-- ── RIGHT: Record Payment form ── -->
    <right>
        <VBox fx:id="paymentFormPanel" styleClass="form-panel" spacing="16"
              minWidth="300" maxWidth="300" managed="false" visible="false">

            <Label styleClass="form-panel-title" text="Record Payment"/>
            <Region styleClass="divider-line"/>

            <!-- Client selector -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="CLIENT *"/>
                <ComboBox fx:id="fPayClient" styleClass="combo-box"
                          promptText="Select client..." prefWidth="Infinity"/>
            </VBox>

            <!-- Membership selector -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="MEMBERSHIP *"/>
                <ComboBox fx:id="fPayMembership" styleClass="combo-box"
                          promptText="Select membership..." prefWidth="Infinity"
                          onAction="#handleMembershipSelected"/>
            </VBox>

            <!-- Amount -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="AMOUNT (NPR) *"/>
                <TextField fx:id="fPayAmount" styleClass="text-field" promptText="e.g. 5000.00"/>
            </VBox>

            <!-- Payment Date -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="PAYMENT DATE *"/>
                <DatePicker fx:id="fPayDate" styleClass="date-picker" prefWidth="Infinity"/>
            </VBox>

            <!-- Payment Method -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="PAYMENT METHOD *"/>
                <ComboBox fx:id="fPayMethod" styleClass="combo-box" prefWidth="Infinity"
                          promptText="Select method..."/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="payFormErrorLabel" styleClass="text-danger"
                   text="" wrapText="true" style="-fx-font-size:12px;"/>

            <!-- Buttons -->
            <VBox spacing="8">
                <Button fx:id="savePaymentBtn" styleClass="btn-primary"
                        text="Save Payment" maxWidth="Infinity"
                        onAction="#handleSavePayment"
                        style="-fx-background-color:#CCFF00; -fx-text-fill:#0B0B0B; -fx-font-weight:bold; -fx-font-size:13px; -fx-pref-height:40px;"/>
                <Button styleClass="btn-secondary"
                        text="Cancel" maxWidth="Infinity"
                        onAction="#handleCancelPayForm"/>
            </VBox>

        </VBox>
    </right>

</BorderPane>
