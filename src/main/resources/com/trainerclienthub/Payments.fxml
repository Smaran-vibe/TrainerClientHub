<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trainerclienthub.controller.PaymentController"
            styleClass="root-pane"
            stylesheets="@css/neon-theme.css">

    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-logo-box" spacing="4">
                <Label styleClass="sidebar-logo-title" text="TCH"/>
                <Label styleClass="sidebar-logo-sub" text="TRAINER CLIENT HUB"/>
            </VBox>
            <Region styleClass="sidebar-divider"/>
            <Label styleClass="sidebar-section-label" text="MAIN MENU"/>
            <HBox fx:id="navDashboard" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavDashboard">
                <Label styleClass="nav-icon" text="⊞"/>
                <Label text="Dashboard"/>
            </HBox>
            <HBox fx:id="navClients" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavClients">
                <Label styleClass="nav-icon" text="👥"/>
                <Label text="Clients"/>
            </HBox>
            <HBox fx:id="navWorkouts" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavWorkouts">
                <Label styleClass="nav-icon" text="🏋"/>
                <Label text="Workouts"/>
            </HBox>
            <HBox fx:id="navMemberships" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavMemberships">
                <Label styleClass="nav-icon" text="🪪"/>
                <Label text="Memberships"/>
            </HBox>
            <HBox fx:id="navSessions" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavSessions">
                <Label styleClass="nav-icon" text="📅"/>
                <Label text="Sessions"/>
            </HBox>
            <HBox fx:id="navPayments" styleClass="nav-item, nav-item-active" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavPayments">
                <Label styleClass="nav-icon" text="💳"/>
                <Label text="Payments"/>
            </HBox>
            <HBox fx:id="navTrainers" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavTrainers">
                <Label styleClass="nav-icon" text="🧑‍🏫"/>
                <Label text="Trainers"/>
            </HBox>
            <HBox fx:id="navReports" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#handleNavReports">
                <Label styleClass="nav-icon" text="📊"/>
                <Label text="Reports"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleLogout">
                <Label styleClass="nav-icon" text="⏻"/>
                <Label text="Logout" style="-fx-text-fill:#AAAAAA;"/>
            </HBox>
        </VBox>
    </left>

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="2">
                <Label styleClass="top-bar-title" text="Payments"/>
                <Label styleClass="top-bar-sub" text="Full ledger for every client"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="avatar-circle">
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="T"/>
            </StackPane>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-area" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="section-title" text="All Payments"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="filter-bar">
                <TextField fx:id="searchField" promptText="Search by Client Name..." prefWidth="260"/>
                <ComboBox fx:id="statusFilterCombo" prefWidth="160" promptText="Filter by status"/>
            </HBox>
            <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colPaymentId" text="Payment ID" prefWidth="120"/>
                    <TableColumn fx:id="colClientName" text="Client Name" prefWidth="220"/>
                    <TableColumn fx:id="colAmount" text="Amount (NPR)" prefWidth="140"/>
                    <TableColumn fx:id="colPaymentDate" text="Date" prefWidth="140"/>
                    <TableColumn fx:id="colMethod" text="Method" prefWidth="110"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                    <TableColumn fx:id="colAction" text="Action" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No payments to show." style="-fx-text-fill:#888888; -fx-font-size:14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
