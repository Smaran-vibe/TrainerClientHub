<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.trainerclienthub.controller.RegisterController"
           styleClass="login-root"
           stylesheets="@css/neon-theme.css">

    <VBox alignment="CENTER" spacing="0">
        <HBox minHeight="4" maxHeight="4" style="-fx-background-color: #CCFF00;" />

        <StackPane VBox.vgrow="ALWAYS">
            <VBox styleClass="login-card" alignment="TOP_CENTER" spacing="0"
                  StackPane.alignment="CENTER"
                  style="-fx-max-width:440px; -fx-min-width:440px;">

                <!-- Branding -->
                <VBox alignment="CENTER" spacing="6">
                        <ImageView fitHeight="140" fitWidth="140" preserveRatio="true">
                            <image>
                                <Image url="@image/Transparent_logo.png"/>
                            </image>
                        </ImageView>
                    <Label styleClass="login-title" text="CREATE ACCOUNT"/>
                    <Label styleClass="login-subtitle" text="Join Trainer Client Hub"/>
                </VBox>

                <Region minHeight="28" />

                <!-- Full Name -->
                <VBox spacing="6">
                    <Label styleClass="login-field-label" text="FULL NAME"/>
                    <TextField fx:id="nameField" styleClass="text-field"
                               promptText="e.g. Smaran Aryal" prefWidth="352"/>
                </VBox>

                <Region minHeight="14" />

                <!-- Email -->
                <VBox spacing="6">
                    <Label styleClass="login-field-label" text="EMAIL ADDRESS"/>
                    <TextField fx:id="emailField" styleClass="text-field"
                               promptText="trainer@gymhub.com" prefWidth="352"/>
                </VBox>

                <Region minHeight="14" />

                <!-- Phone -->
                <VBox spacing="6">
                    <Label styleClass="login-field-label" text="PHONE NUMBER"/>
                    <TextField fx:id="phoneField" styleClass="text-field"
                               promptText="+977XXXXXXXXXX" prefWidth="352"/>
                </VBox>

                <Region minHeight="14" />

                <!-- Password -->
                <VBox spacing="6">
                    <Label styleClass="login-field-label" text="PASSWORD"/>
                    <StackPane prefWidth="352" styleClass="login-stack-pane">
                        <TextField fx:id="passwordVisibleField"
                                   styleClass="text-field"
                                   promptText="Min. 8 characters and atleast 1 unique character"
                                   prefWidth="352"/>
                        <PasswordField fx:id="passwordField"
                                       styleClass="password-field"
                                       promptText="Min. 8 characters and atleast 1 unique character"
                                       prefWidth="352"/>
                        <ToggleButton fx:id="showPasswordToggle"
                                      text="👁"
                                      styleClass="icon-button"
                                      onAction="#handleShowPasswordToggle"
                                      StackPane.alignment="CENTER_RIGHT"
                                      translateX="-12"
                                      prefHeight="34"/>
                    </StackPane>
                </VBox>

                <Region minHeight="14" />

                <VBox spacing="6">
                    <Label styleClass="login-field-label" text="CONFIRM PASSWORD"/>
                    <StackPane prefWidth="352" styleClass="login-stack-pane">
                        <TextField fx:id="confirmPasswordVisibleField"
                                   styleClass="text-field"
                                   promptText="Repeat your password"
                                   prefWidth="352"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       styleClass="password-field"
                                       promptText="Repeat your password"
                                       prefWidth="352"/>
                        <ToggleButton fx:id="showConfirmPasswordToggle"
                                      text="👁"
                                      styleClass="icon-button"
                                      onAction="#handleShowConfirmPasswordToggle"
                                      StackPane.alignment="CENTER_RIGHT"
                                      translateX="-12"
                                      prefHeight="34"/>
                    </StackPane>
                </VBox>

                <Region minHeight="8" />

                <!-- Error / info label -->
                <Label fx:id="errorLabel" styleClass="text-danger"
                       text="" wrapText="true" prefWidth="352"
                       style="-fx-font-size:12px;"/>

                <Region minHeight="20" />

                <!-- Register button -->
                <Button fx:id="registerButton"
                        styleClass="btn-primary"
                        text="CREATE ACCOUNT"
                        prefWidth="352"
                        prefHeight="46"
                        onAction="#handleRegister"/>

                <Region minHeight="18" />

                <!-- Login link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Already have an account?"
                           style="-fx-text-fill:#AAAAAA; -fx-font-size:13px;"/>
                    <Hyperlink fx:id="loginLink"
                               styleClass="hyperlink"
                               text="Login"
                               onAction="#handleLoginLink"/>
                </HBox>

            </VBox>
        </StackPane>
    </VBox>
</StackPane>
