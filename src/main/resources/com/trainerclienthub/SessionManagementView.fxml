<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trainerclienthub.controller.SessionController"
            styleClass="root-pane"
            stylesheets="@css/neon-theme.css">

    <!-- ── LEFT: Sidebar ── -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-logo-box" spacing="4">
                <Label styleClass="sidebar-logo-title" text="TCH"/>
                <Label styleClass="sidebar-logo-sub"   text="TRAINER CLIENT HUB"/>
            </VBox>
            <Region styleClass="sidebar-divider"/>
            <Label styleClass="sidebar-section-label" text="MAIN MENU"/>
            <HBox fx:id="navDashboard" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavDashboard">
                <Label styleClass="nav-icon" text="⊞"/><Label text="Dashboard"/>
            </HBox>
            <HBox fx:id="navClients" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavClients">
                <Label styleClass="nav-icon" text="👥"/><Label text="Clients"/>
            </HBox>
            <HBox fx:id="navWorkouts" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavWorkouts">
                <Label styleClass="nav-icon" text="🏋"/><Label text="Workouts"/>
            </HBox>
            <HBox fx:id="navMemberships" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavMemberships">
                <Label styleClass="nav-icon" text="🪪"/><Label text="Memberships"/>
            </HBox>
            <HBox styleClass="nav-item, nav-item-active" spacing="12" alignment="CENTER_LEFT">
                <Label styleClass="nav-icon" text="📅"/><Label text="Sessions"/>
            </HBox>
            <HBox fx:id="navPayments" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavPayments">
                <Label styleClass="nav-icon" text="💳"/><Label text="Payments"/>
            </HBox>
            <HBox fx:id="navTrainers" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavTrainers">
                <Label styleClass="nav-icon" text="🧑‍🏫"/><Label text="Trainers"/>
            </HBox>
            <HBox fx:id="navReports" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleNavReports">
                <Label styleClass="nav-icon" text="📊"/><Label text="Reports"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <Region styleClass="sidebar-divider"/>
            <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#handleLogout">
                <Label styleClass="nav-icon" text="⏻"/><Label text="Logout" style="-fx-text-fill:#AAAAAA;"/>
            </HBox>
        </VBox>
    </left>

    <!-- ── TOP: Top bar ── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="2">
                <Label styleClass="top-bar-title" text="Session Management"/>
                <Label styleClass="top-bar-subtitle" text="Schedule, track and manage training sessions"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="avatar-circle">
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="T"/>
            </StackPane>
        </HBox>
    </top>

    <!-- ── CENTER ── -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Summary badges row -->
            <HBox spacing="16">
                <VBox styleClass="summary-card" spacing="8" HBox.hgrow="ALWAYS" prefHeight="90">
                    <Label styleClass="card-label" text="TOTAL SCHEDULED"/>
                    <Label fx:id="scheduledTodayLabel" styleClass="card-value" text="0"/>
                </VBox>
                <VBox styleClass="summary-card" spacing="8" HBox.hgrow="ALWAYS" prefHeight="90">
                    <Label styleClass="card-label" text="TOTAL COMPLETED"/>
                    <Label fx:id="completedTodayLabel"
                           style="-fx-text-fill:#00CC66; -fx-font-size:36px; -fx-font-weight:bold;"
                           text="0"/>
                </VBox>
                <VBox styleClass="summary-card" spacing="8" HBox.hgrow="ALWAYS" prefHeight="90">
                    <Label styleClass="card-label" text="TOTAL CANCELLED"/>
                    <Label fx:id="cancelledTodayLabel"
                           style="-fx-text-fill:#FF4444; -fx-font-size:36px; -fx-font-weight:bold;"
                           text="0"/>
                </VBox>
                <VBox styleClass="summary-card" spacing="8" HBox.hgrow="ALWAYS" prefHeight="90">
                    <Label styleClass="card-label" text="TOTAL THIS WEEK"/>
                    <Label fx:id="weeklyTotalLabel" styleClass="card-value" text="0"/>
                </VBox>
            </HBox>

            <!-- Action bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="sessionSearchField" styleClass="search-field"
                           promptText="Search by client or trainer..."/>
                <DatePicker fx:id="dateFilter" styleClass="date-picker"
                            promptText="Filter by date" prefWidth="160"
                            onAction="#handleDateFilter"/>
                <ComboBox fx:id="statusFilterCombo" styleClass="combo-box"
                          promptText="Filter by status" prefWidth="150"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="scheduleSessionBtn" styleClass="btn-primary"
                        text="+ Schedule Session" onAction="#handleScheduleSession"/>
                <Button fx:id="completeSessionBtn" styleClass="btn-secondary"
                        text="Mark Complete" onAction="#handleCompleteSession"/>
                <Button fx:id="cancelSessionBtn" styleClass="btn-danger"
                        text="Cancel" onAction="#handleCancelSession"/>
            </HBox>

            <!-- Sessions table -->
            <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colSessionId"     text="ID"       prefWidth="60"/>
                    <TableColumn fx:id="colSessionClient" text="CLIENT"   prefWidth="160"/>
                    <TableColumn fx:id="colSessionTrainer" text="TRAINER" prefWidth="140"/>
                    <TableColumn fx:id="colSessionDate"   text="DATE"     prefWidth="120"/>
                    <TableColumn fx:id="colSessionTime"   text="TIME"     prefWidth="100"/>
                    <TableColumn fx:id="colSessionStatus" text="STATUS"   prefWidth="130"/>
                    <TableColumn fx:id="colSessionNotes"  text="NOTES"    prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="No sessions found for selected filters."
                           style="-fx-text-fill:#555555; -fx-font-size:13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

    <!-- ── RIGHT: Schedule session form ── -->
    <right>
        <VBox fx:id="sessionFormPanel" styleClass="form-panel" spacing="16"
              minWidth="300" maxWidth="300" managed="false" visible="false">

            <Label fx:id="sessionFormTitle" styleClass="form-panel-title" text="Schedule Session"/>
            <Region styleClass="divider-line"/>

            <!-- Client -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="CLIENT *"/>
                <ComboBox fx:id="fSessionClient" styleClass="combo-box"
                          promptText="Select client..." prefWidth="Infinity"/>
            </VBox>

            <!-- Session date -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="SESSION DATE *"/>
                <DatePicker fx:id="fSessionDate" styleClass="date-picker" prefWidth="Infinity"/>
            </VBox>

            <!-- Session time -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="SESSION TIME *"/>
                <TextField fx:id="fSessionTime" styleClass="text-field"
                           promptText="e.g. 08:00"/>
            </VBox>

            <!-- Notes -->
            <VBox spacing="5">
                <Label styleClass="form-label" text="NOTES"/>
                <TextArea fx:id="fSessionNotes" styleClass="text-area"
                          promptText="Optional notes..." prefRowCount="3" wrapText="true"/>
            </VBox>

            <!-- Session balance preview -->
            <VBox fx:id="balancePreviewBox" spacing="4"
                  style="-fx-background-color:#1A1A1A; -fx-background-radius:8; -fx-padding:10;"
                  managed="false" visible="false">
                <Label text="SESSION BALANCE" style="-fx-text-fill:#555555; -fx-font-size:10px;"/>
                <Label fx:id="sessionBalancePreview"
                       style="-fx-text-fill:#CCFF00; -fx-font-size:20px; -fx-font-weight:bold;"
                       text="0 remaining"/>
            </VBox>

            <!-- Validation error -->
            <Label fx:id="sessionFormErrorLabel" styleClass="text-danger"
                   text="" wrapText="true" style="-fx-font-size:12px;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="10" minHeight="40" alignment="center">
                <Button fx:id="saveSessionBtn" styleClass="btn-primary"
                        text="Save Session" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        onAction="#handleSaveSession"/>
                <Button fx:id="cancelSessionFormBtn" styleClass="btn-secondary"
                        HBox.hgrow="ALWAYS"
                        text="Cancel" onAction="#handleCancelSessionForm"/>
            </HBox>

        </VBox>
    </right>

</BorderPane>
